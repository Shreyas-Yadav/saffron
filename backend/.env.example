# Copy to .env and fill in. .env is gitignored.

# Which LLM backend: "gemini" (Google AI Studio), "anthropic" (first-party Claude
# API), or "vertex" (Claude on Vertex AI).
LLM_PROVIDER=gemini

# --- Gemini (LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=your_key_here
# Optional override; defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# --- Claude, first-party Anthropic API (LLM_PROVIDER=anthropic) ---
# Just an API key from console.anthropic.com — no GCP project or billing setup.
ANTHROPIC_API_KEY=your_anthropic_key_here
# Bare first-party model ID; defaults to claude-opus-4-8.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Claude on Vertex AI (LLM_PROVIDER=vertex) ---
# Auth is GCP Application Default Credentials, NOT an API key:
#   gcloud auth application-default login
# The model must be enabled in your project's Vertex Model Garden for the region.
VERTEX_PROJECT_ID=your_gcp_project_id
# "global" (recommended), a multi-region ("us"/"eu"), or a specific region.
VERTEX_REGION=global
# Bare first-party model ID; defaults to claude-opus-4-8.
VERTEX_MODEL=claude-opus-4-8
